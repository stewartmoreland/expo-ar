{
  "name": "expo-ar",
  "version": "0.1.0",
  "description": "Augmented Reality module bridging iOS ARKit and Android ARCore",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "node internal/module_scripts/test.js",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-ar",
    "ExpoAr"
  ],
  "repository": "https://github.com/stewartmoreland/expo-ar",
  "bugs": {
    "url": "https://github.com/stewartmoreland/expo-ar/issues"
  },
  "author": "Stewart Moreland <stewartmoreland@users.noreply.github.com> (https://github.com/stewartmoreland)",
  "license": "MIT",
  "homepage": "https://github.com/stewartmoreland/expo-ar#readme",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.1.1",
    "babel-preset-expo": "~55.0.8",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^56.0.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.0.0",
    "react-native": "0.82.1",
    "react-test-renderer": "19.2.7",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "globalSetup": "<rootDir>/jest.globalSetup.js",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/example/features/__tests__"
    ]
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
