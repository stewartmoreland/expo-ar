{
  "expo": {
    "name": "expo-ar-example",
    "slug": "expo-ar-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "expo.module.ar.example"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "expo.module.ar.example",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "../app.plugin.js",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera for AR.",
          "arRequired": false,
          "geospatial": true,
          "locationPermission": "Allow $(PRODUCT_NAME) to use your location to place AR content at real-world places.",
          "arcoreApiKey": "REPLACE_WITH_YOUR_ARCORE_API_KEY"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f452a75d-c6c1-4726-8bf9-7506770b4b67"
      }
    }
  }
}
