# EAS Build uses this file INSTEAD of .gitignore when present.
#
# expo-ar is a local module consumed by example/ via autolinking. Its config
# plugin entry (app.plugin.js) does `require('./plugin/build')`, and the JS
# module's package "main" is build/index.js. Both are git-ignored build output
# (.gitignore's blanket `build/` rule), so a plain .gitignore archive omits them
# and the build fails in the "Read app config" phase.
#
# So this file deliberately does NOT use a blanket `build/` rule. Instead it
# excludes only the heavy NATIVE build dirs by path, leaving the compiled JS
# (build/, plugin/build/) in the archive where the build needs them.

# node.js
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Expo
.expo/*

# TypeScript incremental build cache
*.tsbuildinfo

# OSX
.DS_Store

# Editors
.vscode/
.idea
jsconfig.json

# Native build output (explicit paths — do NOT use a blanket `build/`)
/android/build/
/android/app/build/
/example/android/build/
/example/android/app/build/
/example/ios/build/
.gradle
.cxx
DerivedData
*.xcuserstate
project.xcworkspace
local.properties
example/ios/Pods
example/vendor/
